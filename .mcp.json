{
  "mcpServers": {
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--executablePath",
        "/usr/bin/chromium-browser",
        "--chromeArg",
        "--no-sandbox",
        "--chromeArg",
        "--disable-setuid-sandbox"
      ]
    }
  }
}
